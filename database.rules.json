{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'desenvolvedor' || root.child('users').child(auth.uid).child('roles').child('0').val() === 'admin' || root.child('users').child(auth.uid).child('roles').child('0').val() === 'superadmin' || root.child('users').child(auth.uid).child('roles').child('0').val() === 'desenvolvedor' || root.child('users').child(auth.uid).child('roles').child('1').val() === 'admin' || root.child('users').child(auth.uid).child('roles').child('1').val() === 'superadmin' || root.child('users').child(auth.uid).child('roles').child('1').val() === 'desenvolvedor'"
      },
      ".indexOn": ["deletedAt", "roleUpdatedAt"]
    },
    "produtos": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["nome", "deletedAt"]
    },
    "clientes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["nome", "deletedAt"]
    },
    "vendas": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["vendedorId", "createdAt", "deletedAt", "clienteId"]
    },
    "despesas": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usuarioId", "createdAt", "deletedAt"]
    },
    "despesas-tipos": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "entradas": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["produtoId", "createdAt"]
    },
    "ciclos": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["vendedorId", "status", "abertoEm"]
    },
    "rankings": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pagamentos": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "rotas": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usuarioId", "createdAt"]
    },
    "rotas_meta": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usuarioId", "createdAt"]
    },
    "rotas_gpx": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "analytics": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"],
      "anonimo": {
        ".write": true
      }
    },
    "vales": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["funcionarioId", "data"]
    },
    "depositos": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["vendedorId", "data", "deletedAt"]
    }
  }
}
